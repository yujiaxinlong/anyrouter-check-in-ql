# AnyRouter 账号配置
ANYROUTER_ACCOUNTS=[{"cookies":{"session":"你的session值"},"api_user":"你的api_user值"}]

# 可选：自定义 Provider 配置
# 例：把 anyrouter 的 WAF 绕过关掉（直接用 cookie 调接口，不启动 Playwright）
# PROVIDERS={"anyrouter":{"domain":"https://anyrouter.top","bypass_method":null}}

# 可选：Playwright 是否以无头模式启动（默认 1=无头，本地调试可设 0）
# PLAYWRIGHT_HEADLESS=1

# 通知配置请直接在青龙面板的「环境变量」中设置（如 DINGDING_WEBHOOK、PUSH_KEY 等），
# 由青龙自带的 notify.py 统一处理。本项目不再维护通知逻辑。
