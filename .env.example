# AnyRouter 账号配置
ANYROUTER_ACCOUNTS=[{"cookies":{"session":"你的session值"},"api_user":"你的api_user值"}]

# 可选：Playwright 是否以无头模式启动（默认 1=无头，本地调试可设 0）
# PLAYWRIGHT_HEADLESS=1

# 可选：自定义 Provider 配置（仅在对接其它 NewAPI/OneAPI 站点时使用）
# anyrouter 和 agentrouter 已内置默认配置，正常使用不需要设。
# 注意：anyrouter 必须保留 bypass_method="waf_cookies"，否则会被 WAF 拒。
# PROVIDERS={"customrouter":{"domain":"https://custom.example.com"}}

# 通知配置请直接在青龙面板的「环境变量」或「通知设置」中设置，
# 由青龙自带的 notify.py 统一处理。本项目不再维护通知逻辑。
